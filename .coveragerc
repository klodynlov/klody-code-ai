[run]
branch = True
source = agent,tools,api
omit =
    */__pycache__/*
    */tests/*
    */.venv/*
    */lora/*
    */bench/*
    */imports/*
    # api/server.py reste exclu : la couverture du chemin WS chat
    # (orchestrator wrappé + streaming événementiel) demanderait des
    # mocks LLM lourds non encore en place. Routes REST + WS handshake
    # déjà couvertes par tests/integration/{test_websocket,test_api_routes}.py.
    # À réintégrer quand un FakeLLMClient compatible OpenAI streaming
    # sera branché à _build_streaming_orchestrator.
    api/server.py

[report]
# Gate à 70% : valeur réaliste avec orchestrator + profiler réintégrés au
# scope (mais api/server.py encore exclu — voir omit ci-dessus). Cible
# d'évolution : 75% une fois que le chemin WS chat sera testable via un
# FakeLLMClient compatible OpenAI streaming.
fail_under = 70
precision = 1
show_missing = True
skip_covered = False
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    \.\.\.

[html]
directory = htmlcov

[xml]
output = coverage.xml
