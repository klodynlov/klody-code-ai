# Environnement
.env
.env.local
.env.production
.env.staging

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.Python
env/
venv/
.venv/

# Tests
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Logs (garder le dossier). L'état persistant — sessions, long_term.json,
# semantic_memory.db — vit désormais hors du repo, dans MEMORY_DIR (~/.klody/data
# par défaut) : git ne le voit plus, rien à ignorer ici.
logs/*.log
logs/user_profile.json
logs/distill_book_last_invalid.json
logs/distill/
!logs/.gitkeep

# macOS
.DS_Store
.AppleDouble

# IDE
.vscode/
.idea/
*.swp
.aider*

# Claude Code
.claude/

# Aperçu local
_preview/
preview/

# Artefacts générés téléchargeables (Excel, etc.)
_downloads/

# Images uploadées par le front (vision B-lite)
_uploads/

# Bench results (locaux, gros JSON)
bench/results/*.json
bench/results/*.md
!bench/results/.gitkeep

# Mémoire agent
memory/

# Klody cache (conventions, erreurs récurrentes — Roadmap v2 #8)
.klody/

# PID files de l'orchestrateur d'inférence locale (start-local-ai.sh)
.run/
graphify-out/

# artefacts runtime (régénérables)
.env.bak*
data/
skills/*.json
