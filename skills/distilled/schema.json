{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://klody.local/schemas/distilled-skill.json",
  "title": "Klody distilled skill",
  "description": "Méthode actionnable distillée depuis un livre, sans extrait textuel. Voir skills/distilled/README.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["skill", "domain", "description", "principles", "workflow", "checklist"],
  "properties": {
    "skill": {
      "type": "string",
      "minLength": 2,
      "maxLength": 80
    },
    "domain": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]{1,30}$"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 400
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["book", "author"],
      "properties": {
        "book":   { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "year":   { "type": "integer", "minimum": 0, "maximum": 2100 }
      }
    },
    "principles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": { "type": "string", "minLength": 4 }
    },
    "workflow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["step", "purpose", "guidelines"],
        "properties": {
          "step":       { "type": "string", "minLength": 2 },
          "purpose":    { "type": "string", "minLength": 4 },
          "guidelines": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 4 }
          },
          "pitfalls": {
            "type": "array",
            "items": { "type": "string", "minLength": 4 }
          }
        }
      }
    },
    "checklist": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 4 }
    },
    "vocabulary": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["term", "definition"],
        "properties": {
          "term":       { "type": "string", "minLength": 1 },
          "definition": { "type": "string", "minLength": 4 }
        }
      }
    },
    "heuristics": {
      "type": "array",
      "items": { "type": "string", "minLength": 4 }
    },
    "antipatterns": {
      "type": "array",
      "items": { "type": "string", "minLength": 4 }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["context", "outcome"],
        "properties": {
          "context": { "type": "string", "minLength": 4 },
          "outcome": { "type": "string", "minLength": 4 }
        }
      }
    }
  }
}
