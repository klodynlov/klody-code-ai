# Backend LLM actif : mlx (Apple Silicon, recommandé) | ollama
BACKEND=mlx

# --- MLX (Apple Silicon — voir README-local-ai.md) ---
MLX_BASE_URL=http://localhost:8080/v1
# Cerveau agentique (défaut Klody) — port 8080
MLX_MODEL=unsloth/Qwen3.6-35B-A3B-MLX-8bit
# Spécialiste code (Aider lourd) — port 8081
MLX_CODE_MODEL=mlx-community/Qwen3-Coder-30B-A3B-Instruct-8bit
MLX_CODE_PORT=8081
# Coupe le raisonnement des modèles "thinking" (obligatoire pour Qwen3.6 ;
# ignoré par les modèles non-thinking). Garder les quotes (espace dans le JSON).
MLX_CHAT_TEMPLATE_ARGS='{"enable_thinking": false}'

# --- Vision (VL) — outil analyser_image ---
# "vision" = alias routé par le gateway Klody Core (:8090) vers le worker mlx_vlm
# (modèle Qwen2.5-VL). Vide → outil enregistré mais désactivé (dégradation propre).
# Active après provisioning (mlx-vlm + modèle VL téléchargés côté gateway).
VL_MODEL=vision
VL_BASE_URL=http://localhost:8090/v1
#VL_MAX_TOKENS=1024
#VL_MAX_IMAGE_MB=12

# --- Ollama (fallback) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
# Clé API fictive requise par le SDK OpenAI
OLLAMA_API_KEY=ollama
# Modèle Ollama (si BACKEND=ollama)
MODEL_NAME=qwen2.5-coder:32b

# Dossier racine sur lequel l'agent peut travailler (sandbox)
PROJECT_ROOT=/Users/ton-nom/mon-projet

# Racines supplémentaires où Klody peut lire/écrire (multi-projets),
# séparées par ':'. PROJECT_ROOT est toujours autorisé. Les fichiers
# sensibles (.env, clés, certificats) restent bloqués partout.
# Défaut si non défini : PROJECT_ROOT + PROJECTS_DIR.
# ALLOWED_ROOTS=/Users/ton-nom/Projets:/Users/ton-nom/work:/Users/ton-nom/sites

# Limites
MAX_FILE_SIZE=1048576
# Plafond d'itérations de la boucle ReAct. Sert aussi de plafond au budget que
# le routeur attribue par difficulté (easy:6 / medium:14 / hard:25). Le mettre
# trop bas (ex. 10) rabote les tâches "hard" → l'agent s'arrête avant la fin.
MAX_ITERATIONS=25
MAX_MESSAGES=50
SUBPROCESS_TIMEOUT=30

# LibraryBrain / MCP (Phase 4-5)
LIBRARYBRAIN_URL=http://127.0.0.1:8765/api/ask
# Chemin vers le dépôt library-brain (démarrage automatique au lancement de Klody)
LIBRARYBRAIN_DIR=/Users/ton-nom/library-brain
MCP_SERVER_URL=http://127.0.0.1:8082/mcp

# Serveur MCP PROPRE de Klody (expose ses outils à des clients externes type
# Claude Desktop). Port HTTP : 8087 par défaut — éviter 8083 (= MLX_CODE_PORT).
KLODY_MCP_PORT=8087

# Serveurs MCP externes que KLODY CONSOMME (client MCP).
# JSON {nom: cible}, cible = URL HTTP ou chemin de script. Les outils découverts
# sont exposés au LLM sous mcp__<nom>__<outil>. Un serveur down est ignoré au boot.
# Exemple (active Gmail :8084 et/ou le serveur Web :8085, lancés en --http) :
# KLODY_MCP_SERVERS={"gmail":"http://127.0.0.1:8084/mcp","web":"http://127.0.0.1:8085/mcp"}

# --- Serveur MCP Gmail (klody_mcp/gmail_server.py) ---
# Authentification par mot de passe d'application Google (PAS le mot de passe du compte).
# Générer sur https://myaccount.google.com/apppasswords (2FA requise).
GMAIL_ADDRESS=toi@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
# Optionnels (valeurs par défaut Gmail)
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=465
# Transport du serveur MCP : stdio (défaut) | http
GMAIL_MCP_TRANSPORT=stdio
GMAIL_MCP_PORT=8084

# --- Serveur MCP Web (klody_mcp/web_server.py) — LECTURE SEULE ---
# Outils fetch_url + web_search (DuckDuckGo, sans clé). Garde-fous : GET only,
# http/https only, IP privées/loopback refusées (anti-SSRF), taille plafonnée.
# Aucune authentification. Lancer : ./scripts/start-web-mcp.sh --http
WEB_MCP_TRANSPORT=stdio
WEB_MCP_PORT=8085
# Réglages optionnels (valeurs par défaut)
# WEB_FETCH_TIMEOUT=15
# WEB_FETCH_MAX_BYTES=2000000
# WEB_FETCH_MAX_CHARS=8000
# WEB_SEARCH_RESULTS=8

# VocalBrain MCP — génération de chant (pont vers le daemon local-suno :8766)
VOCALBRAIN_MCP_TRANSPORT=stdio
VOCALBRAIN_MCP_PORT=8086
VOCALBRAIN_MCP_HOST=127.0.0.1
LOCALSUNO_URL=http://127.0.0.1:8766

# --- Outil SQL runtime (run_sql, SQLite local sandboxé) ---
# Lecture seule par défaut : l'outil ne peut que LIRE les bases SQLite confinées
# aux racines autorisées. Passe à true pour autoriser aussi INSERT/UPDATE/CREATE…
# (le confinement — authorizer default-deny, blocage ATTACH/VACUUM INTO/extensions,
# anti-DoS — s'applique dans les deux modes).
# SQL_WRITE_ENABLED=false

# --- Outil Git runtime (git_control) ---
# Introspection Git toujours en lecture seule. Passe à true pour autoriser les
# mutations LOCALES add/commit (réversibles). push/pull et les opérations
# destructives (reset/checkout/clean/rebase) restent hors de l'outil quoi qu'il arrive.
# GIT_WRITE_ENABLED=false

# --- Outil Docker runtime (docker_control) ---
# Introspection Docker toujours en lecture seule. `docker run` (mutation) exige CE
# flag à true ET une allowlist d'images non vide. Aucun flag utilisateur n'est
# accepté : --network none, --cap-drop ALL, no-new-privileges, limites ressources.
# DOCKER_WRITE_ENABLED=false
# DOCKER_ALLOWED_IMAGES=python:3.12,alpine,ghcr.io/moi/
